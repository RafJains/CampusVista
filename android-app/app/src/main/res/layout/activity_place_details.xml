<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cv_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/placeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/cv_ink"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/placeType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/cv_green_dark"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/placeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/cv_card"
            android:padding="14dp"
            android:textColor="@color/cv_ink"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/placeCheckpoint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/cv_muted"
            android:textSize="14sp" />

        <Button
            android:id="@+id/routeHereButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/cv_button_primary"
            android:text="Route Here"
            android:textColor="@color/cv_white" />

        <Button
            android:id="@+id/setCurrentButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/cv_button_secondary"
            android:text="Set As Current Location"
            android:textColor="@color/cv_green_dark" />
    </LinearLayout>
</ScrollView>
