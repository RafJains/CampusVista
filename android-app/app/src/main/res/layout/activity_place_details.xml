<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cv_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/placeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/cv_ink"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/placeType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/cv_map_badge"
            android:paddingBottom="8dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="8dp"
            android:textColor="@color/cv_green_dark"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/placeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/cv_card"
            android:elevation="2dp"
            android:lineSpacingExtra="3dp"
            android:padding="18dp"
            android:textColor="@color/cv_ink"
            android:textSize="15sp" />

        <Button
            android:id="@+id/routeHereButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/cv_button_primary"
            android:elevation="2dp"
            android:minHeight="48dp"
            android:text="Start Navigation"
            android:textColor="@color/cv_white" />

        <Button
            android:id="@+id/placePanoButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/cv_button_secondary"
            android:elevation="1dp"
            android:minHeight="48dp"
            android:text="View Pano"
            android:textColor="@color/cv_navy" />

        <Button
            android:id="@+id/setCurrentButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/cv_button_secondary"
            android:elevation="1dp"
            android:minHeight="48dp"
            android:text="Use As Start"
            android:textColor="@color/cv_navy" />
    </LinearLayout>
</ScrollView>
