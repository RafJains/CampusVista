<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cv_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/setLocationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Current Location"
            android:textColor="@color/cv_ink"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/selectedLocationLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/cv_muted"
            android:textSize="14sp" />

        <Button
            android:id="@+id/openSearchLocationButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/cv_button_primary"
            android:text="Search Outdoor Location"
            android:textColor="@color/cv_white" />

        <Button
            android:id="@+id/cameraDetectButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/cv_button_secondary"
            android:text="Use Camera to Detect Outdoor Location"
            android:textColor="@color/cv_green_dark" />

        <TextView
            android:id="@+id/checkpointPickerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Select On Map"
            android:textColor="@color/cv_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/locationCheckpointList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
