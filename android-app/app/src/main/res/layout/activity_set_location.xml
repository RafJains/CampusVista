<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cv_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/setLocationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose Start"
            android:textColor="@color/cv_ink"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/selectedLocationLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/cv_card"
            android:elevation="1dp"
            android:padding="14dp"
            android:textColor="@color/cv_muted"
            android:textSize="14sp" />

        <Button
            android:id="@+id/openSearchLocationButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/cv_button_primary"
            android:elevation="2dp"
            android:minHeight="48dp"
            android:text="Search Location"
            android:textColor="@color/cv_white" />

        <Button
            android:id="@+id/openPhotoRecognitionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/cv_button_secondary"
            android:minHeight="48dp"
            android:text="Recognize from Photo"
            android:textColor="@color/cv_ink" />

        <TextView
            android:id="@+id/checkpointPickerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Locations"
            android:textColor="@color/cv_ink"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/locationCheckpointList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
