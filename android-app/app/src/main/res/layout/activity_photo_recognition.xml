<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cv_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/recognitionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recognize Location"
            android:textColor="@color/cv_ink"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recognitionStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/cv_card"
            android:elevation="1dp"
            android:padding="14dp"
            android:textColor="@color/cv_muted"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/recognitionPhotoPreview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/cv_map_panel"
            android:contentDescription="Selected campus photo"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <Button
            android:id="@+id/takePhotoButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/cv_button_primary"
            android:elevation="2dp"
            android:minHeight="48dp"
            android:text="Take Photo"
            android:textColor="@color/cv_white" />

        <Button
            android:id="@+id/chooseGalleryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/cv_button_secondary"
            android:minHeight="48dp"
            android:text="Choose From Gallery"
            android:textColor="@color/cv_ink" />

        <Button
            android:id="@+id/retryRecognitionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/cv_button_secondary"
            android:minHeight="48dp"
            android:text="Check Again"
            android:textColor="@color/cv_ink" />

        <TextView
            android:id="@+id/recognitionMatchesTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Matches"
            android:textColor="@color/cv_ink"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/recognitionMatchesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
