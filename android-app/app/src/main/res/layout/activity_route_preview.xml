<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cv_surface"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/previewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Route Preview"
        android:textColor="@color/cv_ink"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/previewMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/cv_card"
        android:elevation="2dp"
        android:padding="16dp"
        android:textColor="@color/cv_ink"
        android:textSize="14sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/routeStepsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <Button
        android:id="@+id/startNavigationButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/cv_button_primary"
        android:elevation="2dp"
        android:text="Start Navigation"
        android:textColor="@color/cv_white" />

    <Button
        android:id="@+id/changeRouteButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/cv_button_secondary"
        android:elevation="1dp"
        android:text="Change Route"
        android:textColor="@color/cv_blue_dark" />
</LinearLayout>
