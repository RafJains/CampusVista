<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cv_surface"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/routeOptionsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Route Options"
        android:textColor="@color/cv_ink"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/routeStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/cv_card"
        android:elevation="2dp"
        android:padding="16dp"
        android:textColor="@color/cv_ink"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/routeDestination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/cv_card"
        android:elevation="2dp"
        android:padding="16dp"
        android:textColor="@color/cv_ink"
        android:textSize="15sp" />

    <Button
        android:id="@+id/shortestPathButton"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/cv_button_primary"
        android:elevation="2dp"
        android:text="Generate Route"
        android:textColor="@color/cv_white" />

    <Button
        android:id="@+id/changeStartButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/cv_button_secondary"
        android:elevation="1dp"
        android:text="Change Start"
        android:textColor="@color/cv_blue_dark" />
</LinearLayout>
