<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cv_surface"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/navTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Outdoor Navigation"
        android:textColor="@color/cv_ink"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/navSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/cv_card"
        android:elevation="1dp"
        android:padding="14dp"
        android:textColor="@color/cv_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/navProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/cv_map_badge"
        android:paddingBottom="8dp"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:textColor="@color/cv_blue_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/navInstruction"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@drawable/cv_card"
        android:elevation="2dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:padding="22dp"
        android:textColor="@color/cv_ink"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/navPanoPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@drawable/cv_card"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/navPanoImage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:adjustViewBounds="true"
            android:background="@drawable/cv_map_panel"
            android:clipToOutline="true"
            android:contentDescription="Current checkpoint panorama"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/navPanoCheckpointName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/cv_ink"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navPanoInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/cv_muted"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/navPanoPreviousButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/cv_button_secondary"
                android:text="Previous"
                android:textColor="@color/cv_blue_dark" />

            <Button
                android:id="@+id/navPanoNextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/cv_button_primary"
                android:elevation="2dp"
                android:text="Next"
                android:textColor="@color/cv_white" />
        </LinearLayout>

        <Button
            android:id="@+id/navBackToMapButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/cv_button_secondary"
            android:text="Back to Map"
            android:textColor="@color/cv_blue_dark" />
    </LinearLayout>

    <Button
        android:id="@+id/navPanoButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/cv_button_secondary"
        android:text="Pano Mode"
        android:textColor="@color/cv_blue_dark" />

    <Button
        android:id="@+id/navNextButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/cv_button_primary"
        android:elevation="2dp"
        android:text="Next"
        android:textColor="@color/cv_white" />

    <Button
        android:id="@+id/navCompleteButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/cv_button_secondary"
        android:text="Complete Route"
        android:textColor="@color/cv_blue_dark" />
</LinearLayout>
