<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="@color/cv_surface"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_launcher" />

        <TextView
            android:id="@+id/navBrandName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/app_name"
            android:textColor="@color/cv_ink"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/navTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Navigation Steps"
        android:textColor="@color/cv_ink"
        android:textSize="30sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/navMetricRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/navStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/cv_metric_card"
            android:gravity="center_vertical"
            android:lineSpacingExtra="2dp"
            android:minHeight="54dp"
            android:padding="12dp"
            android:singleLine="false"
            android:textColor="@color/cv_ink"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/cv_metric_card"
            android:gravity="center_vertical"
            android:lineSpacingExtra="2dp"
            android:minHeight="54dp"
            android:padding="12dp"
            android:singleLine="false"
            android:textColor="@color/cv_ink"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/navDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/cv_metric_card"
            android:gravity="center_vertical"
            android:minHeight="50dp"
            android:padding="12dp"
            android:singleLine="false"
            android:textColor="@color/cv_ink"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/navProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/cv_green_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/navInstruction"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/cv_card"
        android:elevation="2dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:padding="22dp"
        android:textColor="@color/cv_ink"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/navPanoPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/cv_card"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/navPanoImage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:adjustViewBounds="true"
            android:background="@drawable/cv_map_panel"
            android:clipToOutline="true"
            android:contentDescription="Current panorama"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/navPanoCheckpointName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/cv_ink"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navPanoInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/cv_muted"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/navPanoPreviousButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/cv_button_secondary"
                android:text="Previous"
                android:textColor="@color/cv_navy" />

            <Button
                android:id="@+id/navPanoNextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/cv_button_primary"
                android:elevation="2dp"
                android:text="Next"
                android:textColor="@color/cv_white" />
        </LinearLayout>

        <Button
            android:id="@+id/navBackToMapButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/cv_button_secondary"
            android:text="Steps"
            android:textColor="@color/cv_navy" />
    </LinearLayout>

    <Button
        android:id="@+id/navPanoButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/cv_button_secondary"
        android:minHeight="48dp"
        android:text="Pano Mode"
        android:textColor="@color/cv_navy" />

    <Button
        android:id="@+id/navNextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/cv_button_primary"
        android:elevation="2dp"
        android:minHeight="52dp"
        android:text="Next"
        android:textColor="@color/cv_white" />

    <Button
        android:id="@+id/navCompleteButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/cv_button_secondary"
        android:minHeight="48dp"
        android:text="Finish"
        android:textColor="@color/cv_navy" />
</LinearLayout>
