<resources>
    <style name="Theme.CampusVista" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowBackground">@color/cv_surface</item>
        <item name="android:colorAccent">@color/cv_blue</item>
        <item name="android:navigationBarColor">@color/cv_white</item>
        <item name="android:statusBarColor">@color/cv_blue_dark</item>
        <item name="android:buttonStyle">@style/Widget.CampusVista.Button</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Widget.CampusVista.Button" parent="@android:style/Widget.Material.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans</item>
    </style>
</resources>
