<resources>
    <style name="Theme.CampusVista" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowBackground">@color/cv_surface</item>
        <item name="android:colorAccent">@color/cv_blue</item>
        <item name="android:navigationBarColor">@color/cv_white</item>
        <item name="android:statusBarColor">@color/cv_navy</item>
        <item name="android:buttonStyle">@style/Widget.CampusVista.Button</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowAnimationStyle">@style/CampusVistaActivityAnimation</item>
    </style>

    <style name="Widget.CampusVista.Button" parent="@android:style/Widget.Material.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:singleLine">false</item>
        <item name="android:maxLines">3</item>
        <item name="android:includeFontPadding">true</item>
    </style>

    <style name="CampusVistaActivityAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/cv_activity_enter</item>
        <item name="android:activityOpenExitAnimation">@anim/cv_activity_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/cv_activity_pop_enter</item>
        <item name="android:activityCloseExitAnimation">@anim/cv_activity_pop_exit</item>
    </style>
</resources>
